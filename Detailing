    <!-- Scanner Modal -->
    <div id="scannerModal" class="scanner-modal">
        <div class="scanner-header">
            <div class="scanner-title" id="scannerTitle">Scan Registration</div>
            <button class="close-btn" onclick="closeScanner()">×</button>
        </div>
        <div class="scanner-viewfinder">
            <video id="cameraFeed" autoplay playsinline></video>
            <div class="scan-overlay">
                <div class="scan-line"></div>
            </div>
            <div class="scan-instructions" id="scanInstructions">
                Position text clearly within the red frame and hold steady
            </div>
            <div class="ocr-progress" id="ocrProgress">
                <div id="ocrStatus">Initializing OCR engine...</div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
            </div>
        </div>
        <div class="capture-btn" onclick="captureScan()"></div>
    </div>
    
    <!-- Toast -->
    <div id="toast" class="toast"></div>

    <script>
        // State Management
        let jobs = JSON.parse(localStorage.getItem('detailingJobs_v3') || '[]');
        let currentPhotos = new Array(8).fill(null);
        let currentPhotoIndex = 0;
        let scannerMode = 'reg';
        let stream = null;
        let tesseractWorker = null;
        let isOcrReady = false;
        
        // Initialize Tesseract
        async function initTesseract() {
            if (isOcrReady) return;
            
            try {
                showToast('Loading OCR engine... Please wait');
                tesseractWorker = await Tesseract.createWorker();
                await tesseractWorker.load();
                await tesseractWorker.loadLanguage('eng');
                await tesseractWorker.initialize('eng');
                isOcrReady = true;
                showToast('✓ OCR Ready - You can now scan plates');
            } catch (err) {
                console.error('OCR Init failed:', err);
                showToast('⚠ OCR failed to load. Manual entry only.');
            }
        }
        
        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderJobs();
            initPhotoGrid();
            
            // Set today's date as default for pickup
            document.getElementById('pickupDate').valueAsDate = new Date();
            
            // Pre-init tesseract after short delay
            setTimeout(initTesseract, 1000);
            
            // Setup file input
            document.getElementById('fileInput').onchange = handleFileSelect;
        });
        
        // Photo Grid
        function initPhotoGrid() {
            const grid = document.getElementById('photoGrid');
            const labels = ['Front', 'Rear', 'Left', 'Right', 'Interior', 'Damage', 'Engine', 'VIN Plate'];
            
            grid.innerHTML = '';
            for (let i = 0; i < 8; i++) {
                const slot = document.createElement('div');
                slot.className = 'photo-slot';
                if (currentPhotos[i]) slot.classList.add('has-image');
                slot.onclick = () => selectPhotoSlot(i);
                
                if (currentPhotos[i]) {
                    slot.innerHTML = `<img src="${currentPhotos[i]}" alt="Photo ${i+1}">`;
                } else {
                    slot.innerHTML = `
                        <div class="add-photo-icon">+</div>
                        <div class="photo-label">${labels[i]}</div>
                    `;
                }
                grid.appendChild(slot);
            }
        }
        
        function selectPhotoSlot(index) {
            currentPhotoIndex = index;
            document.getElementById('fileInput').click();
        }
        
        function handleFileSelect(e) {
            const file = e.target.files[0];
            if (!file) return;
            
            if (file.size > 5 * 1024 * 1024) {
                showToast('Photo too large. Max 5MB.');
                return;
            }
            
            const reader = new FileReader();
            reader.onload = (event) => {
                const img = new Image();
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    const MAX_WIDTH = 1200;
                    const scale = MAX_WIDTH / img.width;
                    canvas.width = MAX_WIDTH;
                    canvas.height = img.height * scale;
                    
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    
                    currentPhotos[currentPhotoIndex] = canvas.toDataURL('image/jpeg', 0.7);
                    initPhotoGrid();
                    showToast('✓ Photo added successfully');
                };
                img.src = event.target.result;
            };
            reader.readAsDataURL(file);
            e.target.value = '';
        }
        
        // Scanner Functions
        async function openScanner(mode) {
            scannerMode = mode;
            const modal = document.getElementById('scannerModal');
            const title = document.getElementById('scannerTitle');
            const instructions = document.getElementById('scanInstructions');
            
            modal.classList.add('active');
            
            if (mode === 'reg') {
                title.textContent = 'SCAN REGO PLATE';
                instructions.textContent = 'Position registration plate clearly within the red frame';
            } else {
                title.textContent = 'SCAN COMPLIANCE PLATE';
                instructions.textContent = 'Position VIN/build date plate within the red frame';
            }
            
            try {
                stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { 
                        facingMode: 'environment',
                        width: { ideal: 1920 },
                        height: { ideal: 1080 }
                    } 
                });
                const video = document.getElementById('cameraFeed');
                video.srcObject = stream;
                await video.play();
            } catch (err) {
                showToast('Camera access denied. Check browser permissions.');
                closeScanner();
            }
        }
        
        function closeScanner() {
            document.getElementById('scannerModal').classList.remove('active');
            document.getElementById('ocrProgress').classList.remove('active');
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
                stream = null;
            }
        }
        
        async function captureScan() {
            if (!isOcrReady) {
                await initTesseract();
            }
            
            const video = document.getElementById('cameraFeed');
            const canvas = document.createElement('canvas');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(video, 0, 0);
            
            const progressDiv = document.getElementById('ocrProgress');
            const progressFill = document.getElementById('progressFill');
            const statusText = document.getElementById('ocrStatus');
            
            progressDiv.classList.add('active');
            progressFill.style.width = '20%';
            statusText.textContent = 'Processing image...';
            
            try {
                progressFill.style.width = '50%';
                statusText.textContent = 'Reading text with OCR...';
                
                const result = await tesseractWorker.recognize(canvas.toDataURL('image/jpeg'));
                const text = result.data.text.toUpperCase().trim();
                
                progressFill.style.width = '100%';
                statusText.textContent = 'Processing results...';
                
                console.log('OCR Raw Text:', text);
                
                if (scannerMode === 'reg') {
                    processRegOCR(text);
                } else {
                    processComplianceOCR(text);
                }
                
                setTimeout(() => {
                    closeScanner();
                }, 500);
                
            } catch (err) {
                showToast('OCR failed: ' + err.message);
                closeScanner();
            }
        }
        
        function processRegOCR(text) {
            const patterns = [
                /\b([SST][0-9]{3}[A-Z]{2,3})\b/,
                /\b([0-9]{3}[-\s]?[A-Z]{3})\b/,
                /\b([A-Z]{2,3}[-\s]?[0-9]{2,4})\b/,
                /\b([0-9]{1,3}[-\s][A-Z]{1,3}[-\s][0-9]{0,2})\b/
            ];
            
            let foundReg = null;
            for (let pattern of patterns) {
                const match = text.match(pattern);
                if (match) {
                    foundReg = match[1].replace(/[-\s]/g, '');
                    break;
                }
            }
            
            if (!foundReg) {
                const words = text.split(/\s+/);
                for (let word of words) {
                    const clean = word.replace(/[^A-Z0-9]/g, '');
                    if (clean.length >= 5 && clean.length <= 8 && /[0-9]/.test(clean) && /[A-Z]/.test(clean)) {
                        foundReg = clean;
                        break;
                    }
                }
            }
            
            if (foundReg) {
                document.getElementById('regNumber').value = foundReg;
                showToast('✓ Registration detected: ' + foundReg);
            } else {
                showToast('⚠ No registration detected. Please type manually.');
            }
        }
        
        function processComplianceOCR(text) {
            const vinMatch = text.match(/\b([A-HJ-NPR-Z0-9]{17})\b/);
            if (vinMatch) {
                document.getElementById('vinNumber').value = vinMatch[1];
                showToast('✓ VIN detected');
            }
            
            const datePatterns = [
                /(0[1-9]|1[0-2])[\/\.](19|20)\d{2}/,
                /(JAN|FEB|MAR|APR|MAY|JUN|JUL|AUG|SEP|OCT|NOV|DEC)[\s\.]+(19|20)\d{2}/i,
                /(19|20)\d{2}[\s\.](0[1-9]|1[0-2])/
            ];
            
            for (let pattern of datePatterns) {
                const match = text.match(pattern);
                if (match) {
                    document.getElementById('buildDate').value = match[0];
                    showToast('✓ Build date detected');
                    break;
                }
            }
            
            const makes = ['TOYOTA', 'HOLDEN', 'FORD', 'MAZDA', 'HYUNDAI', 'KIA', 'SUBARU', 'MITSUBISHI', 
                          'NISSAN', 'HONDA', 'VOLKSWAGEN', 'VW', 'BMW', 'MERCEDES', 'AUDI', 'LEXUS'];
            const foundMakes = makes.filter(make => text.includes(make));
            
            if (foundMakes.length > 0 && !document.getElementById('carModel').value) {
                document.getElementById('carModel').value = foundMakes[0] + ' ';
                showToast('✓ Make detected: ' + foundMakes[0]);
            }
            
            if (!vinMatch && foundMakes.length === 0) {
                showToast('⚠ Limited data detected. Check VIN plate positioning.');
            }
        }
        
        // Form Functions
        function toggleCompletionDate() {
            const checkbox = document.getElementById('noCompletion');
            const dateGroup = document.getElementById('completionDateGroup');
            const dateInput = document.getElementById('completionDate');
            
            if (checkbox.checked) {
                dateGroup.style.display = 'none';
                dateInput.disabled = true;
                dateInput.value = '';
            } else {
                dateGroup.style.display = 'block';
                dateInput.disabled = false;
            }
        }
        
        function saveJob(e) {
            e.preventDefault();
            
            const noCompletion = document.getElementById('noCompletion').checked;
            
            const job = {
                id: Date.now(),
                regNumber: document.getElementById('regNumber').value.toUpperCase().trim(),
                carModel: document.getElementById('carModel').value.trim(),
                vinNumber: document.getElementById('vinNumber').value.trim(),
                buildDate: document.getElementById('buildDate').value.trim(),
                pickupDate: document.getElementById('pickupDate').value,
                completionDate: noCompletion ? null : document.getElementById('completionDate').value,
                workRequired: document.getElementById('workRequired').value.trim(),
                priority: document.getElementById('priority').value,
                photos: currentPhotos.filter(p => p),
                created: new Date().toISOString(),
                noCompletion: noCompletion
            };
            
            if (!job.regNumber || !job.carModel || !job.pickupDate || !job.workRequired) {
                showToast('⚠ Please fill in all required fields');
                return;
            }
            
            if (!noCompletion && !job.completionDate) {
                showToast('⚠ Please select completion date or check "No estimated date"');
                return;
            }
            
            jobs.push(job);
            localStorage.setItem('detailingJobs_v3', JSON.stringify(jobs));
            
            showToast('✓ Job created successfully!');
            
            document.getElementById('jobForm').reset();
            currentPhotos = new Array(8).fill(null);
            initPhotoGrid();
            document.getElementById('pickupDate').valueAsDate = new Date();
            document.getElementById('completionDateGroup').style.display = 'block';
            document.getElementById('completionDate').disabled = false;
            
            switchTab('jobs');
        }
        
        // Sorting Logic:
        // 1. Jobs WITH completion date come first (sorted by completion date, oldest first)
        // 2. Jobs WITHOUT completion date over 5 days = URGENT (red, top priority)
        // 3. Jobs WITHOUT completion date under 5 days sorted by pickup date (oldest first)
        function getSortedJobs() {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            
            const jobsWithMeta = jobs.map(job => {
                const pickupDate = new Date(job.pickupDate);
                pickupDate.setHours(0, 0, 0, 0);
                
                const completionDate = job.completionDate ? new Date(job.completionDate) : null;
                if (completionDate) completionDate.setHours(0, 0, 0, 0);
                
                const daysSincePickup = Math.floor((today - pickupDate) / (1000 * 60 * 60 * 24));
                
                // Is this urgent? (No completion date AND over 5 days old)
                const isUrgent = !job.noCompletion && !job.completionDate && daysSincePickup > 5;
                
                // For sorting: use completion date if available, otherwise use pickup date
                const sortDate = completionDate || pickupDate;
                
                const isCompleted = job.priority === 'completed';
                
                return {
                    ...job,
                    pickupDateObj: pickupDate,
                    completionDateObj: completionDate,
                    daysSincePickup,
                    isUrgent,
                    sortDate,
                    isCompleted
                };
            });
            
            const activeJobs = jobsWithMeta.filter(j => !j.isCompleted);
            const completedJobs = jobsWithMeta.filter(j => j.isCompleted);
            
            // Sort active jobs:
            // 1. Urgent jobs (no completion, over 5 days) first
            // 2. Then jobs with completion date (sorted by completion date, oldest first)
            // 3. Then jobs without completion date under 5 days (sorted by pickup, oldest first)
            activeJobs.sort((a, b) => {
                // Urgent jobs (no completion, over 5 days) come first
                if (a.isUrgent && !b.isUrgent) return -1;
                if (!a.isUrgent && b.isUrgent) return 1;
                
                // Both urgent or both not urgent - sort by date (oldest first)
                return a.sortDate - b.sortDate;
            });
            
            // Completed jobs at bottom, sorted by completion date
            completedJobs.sort((a, b) => a.sortDate - b.sortDate);
            
            return [...activeJobs, ...completedJobs];
        }
        
        function renderJobs() {
            const list = document.getElementById('jobsList');
            const empty = document.getElementById('emptyState');
            
            if (jobs.length === 0) {
                list.innerHTML = '';
                empty.style.display = 'block';
                updateStats();
                return;
            }
            
            empty.style.display = 'none';
            
            const sortedJobs = getSortedJobs();
            const today = new Date().toISOString().split('T')[0];
            
            list.innerHTML = sortedJobs.map(job => {
                const hasCompletion = !!job.completionDate;
                const isCompleted = job.isCompleted;
                const isUrgent = job.isUrgent;
                const isDueToday = hasCompletion && job.completionDate === today;
                const isOverdue = hasCompletion && new Date(job.completionDate) < new Date(today);
                
                let statusClass = 'status-pending';
                let statusText = 'ACTIVE';
                let cardClass = hasCompletion ? 'status-dated' : '';
                
                if (isCompleted) {
                    statusClass = 'status-completed';
                    statusText = 'DONE';
                    cardClass = 'status-completed';
                } else if (isUrgent) {
                    statusClass = 'status-urgent';
                    statusText = '⚠ OVER 5 DAYS';
                    cardClass = 'status-urgent';
                } else if (isOverdue) {
                    statusClass = 'status-urgent';
                    statusText = 'OVERDUE';
                    cardClass = 'status-urgent';
                } else if (isDueToday) {
                    statusClass = 'status-urgent';
                    statusText = 'DUE TODAY';
                    cardClass = 'status-dated';
                } else if (job.noCompletion) {
                    statusClass = 'status-tbd';
                    statusText = 'TBD';
                    cardClass = 'status-tbd';
                }
                
                const displayDate = hasCompletion ? job.completionDate : job.pickupDate;
                const dateLabel = hasCompletion ? 'Due' : 'Pick Up';
                
                return `
                    <div class="job-card ${cardClass}" onclick="viewJob(${job.id})">
                        <div class="job-header">
                            <div class="car-info">
                                <h3>${escapeHtml(job.carModel)}</h3>
                                <span class="reg-plate">${escapeHtml(job.regNumber)}</span>
                            </div>
                            <span class="job-status ${statusClass}">${statusText}</span>
                        </div>
                        
                        <div class="job-details">
                            <div class="detail-item">
                                <span class="detail-label">Pick Up</span>
                                <span>${formatDate(job.pickupDate)}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">${dateLabel}</span>
                                <span>${hasCompletion ? formatDate(job.completionDate) : (job.noCompletion ? 'TBD' : formatDate(job.pickupDate))}</span>
                            </div>
                            ${isUrgent ? `
                            <div class="urgent-warning">
                                ⚠ ${job.daysSincePickup} DAYS IN QUEUE - NO COMPLETION DATE SET
                            </div>
                            ` : ''}
                            <div class="detail-item" style="grid-column: 1 / -1;">
                                <span class="detail-label">Work Required</span>
                                <span>${escapeHtml(job.workRequired.substring(0, 60))}${job.workRequired.length > 60 ? '...' : ''}</span>
                            </div>
                            ${job.vinNumber ? `
                            <div class="detail-item">
                                <span class="detail-label">VIN</span>
                                <span>${escapeHtml(job.vinNumber.substring(0, 8))}...</span>
                            </div>
                            ` : ''}
                        </div>
                        
                        ${job.photos.length > 0 ? `
                        <div class="thumbnail-strip">
                            ${job.photos.slice(0, 4).map(photo => `<img src="${photo}" class="thumb">`).join('')}
                            ${job.photos.length > 4 ? `<div class="thumb" style="background: var(--navy); display: flex; align-items: center; justify-content: center; font-size: 12px; color: var(--chrome); border: 2px solid var(--chrome);">+${job.photos.length - 4}</div>` : ''}
                        </div>
                        ` : ''}
                        
                        <button class="delete-btn" onclick="event.stopPropagation(); deleteJob(${job.id})">Delete Job</button>
                    </div>
                `;
            }).join('');
            
            updateStats();
        }
        
        function updateStats() {
            const sortedJobs = getSortedJobs();
            const activeJobs = sortedJobs.filter(j => !j.isCompleted);
            const urgentJobs = activeJobs.filter(j => j.isUrgent);
            
            document.getElementById('activeCount').textContent = activeJobs.length;
            document.getElementById('urgentCount').textContent = urgentJobs.length;
        }
        
        function deleteJob(id) {
            if (confirm('Delete this job permanently?')) {
                jobs = jobs.filter(j => j.id !== id);
                localStorage.setItem('detailingJobs_v3', JSON.stringify(jobs));
                renderJobs();
                showToast('Job deleted');
            }
        }
        
        function viewJob(id) {
            showToast('Tap "New Job" to create additional jobs');
        }
        
        function clearAllData() {
            if (confirm('⚠ WARNING: Delete ALL jobs? This cannot be undone!')) {
                if (confirm('Are you absolutely sure? All data will be lost.')) {
                    jobs = [];
                    localStorage.removeItem('detailingJobs_v3');
                    renderJobs();
                    showToast('All data cleared');
                }
            }
        }
        
        function exportRunSheet() {
            const today = new Date().toLocaleDateString('en-AU');
            const sortedJobs = getSortedJobs();
            const activeJobs = sortedJobs.filter(j => !j.isCompleted);
            
            let printContent = `
                <!DOCTYPE html>
                <html>
                <head>
                    <title>Detailing Auto Care SA - Run Sheet ${today}</title>
                    <style>
                        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap');
                        body { 
                            font-family: 'Roboto', Arial, sans-serif; 
                            padding: 20px; 
                            background: #f5f5f5;
                            color: #0a0e27;
                        }
                        .header { 
                            text-align: center; 
                            margin-bottom: 30px;
                            padding: 20px;
                            background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
                            color: white;
                            border-radius: 12px;
                            border-left: 5px solid #e63946;
                        }
                        .logo-img {
                            max-width: 180px;
                            height: auto;
                            margin-bottom: 10px;
                            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));
                        }
                        h1 { color: #e63946; margin: 10px 0; font-size: 24px; }
                        .meta { color: #666; margin-bottom: 20px; }
                        .urgent-banner {
                            background: #ff0000;
                            color: white;
                            padding: 15px;
                            border-radius: 8px;
                            margin-bottom: 20px;
                            font-weight: 700;
                            text-align: center;
                        }
                        table { 
                            width: 100%; 
                            border-collapse: collapse; 
                            margin-top: 20px;
                            background: white;
                            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                            border-radius: 8px;
                            overflow: hidden;
                        }
                        th { 
                            background: #0a0e27; 
                            color: #c0c0c0;
                            padding: 15px;
                            text-align: left;
                            font-weight: 700;
                            text-transform: uppercase;
                            font-size: 12px;
                            letter-spacing: 1px;
                        }
                        td { 
                            padding: 12px 15px; 
                            border-bottom: 1px solid #eee;
                        }
                        tr:nth-child(even) { background: #f8f9fa; }
                        tr.urgent { background: #ffeeee !important; border-left: 4px solid #ff0000; }
                        tr:hover { background: #e9ecef; }
                        .reg { 
                            font-family: 'Courier New', monospace; 
                            font-weight: 900;
                            background: #ffd700;
                            color: #0a0e27;
                            padding: 4px 8px;
                            border-radius: 4px;
                            border: 2px solid #0a0e27;
                        }
                        .urgent-text { color: #ff0000; font-weight: 700; }
                        .tbd { color: #6c757d; font-style: italic; }
                        .days-old { font-size: 11px; color: #666; }
                        .footer {
                            margin-top: 40px;
                            text-align: center;
                            color: #666;
                            font-size: 12px;
                            border-top: 2px solid #e63946;
                            padding-top: 20px;
                        }
                        @media print {
                            body { background: white; }
                            .no-print { display: none; }
                        }
                    </style>
                </head>
                <body>
                    <div class="header">
                        <h1>Priority Run Sheet</h1>
                        <div class="meta">Generated: ${today} | Total Active Jobs: ${activeJobs.length}</div>
                    </div>
                    
                    ${activeJobs.some(j => j.isUrgent) ? `
                    <div class="urgent-banner">
                        ⚠ WARNING: ${activeJobs.filter(j => j.isUrgent).length} job(s) over 5 days without completion date!
                    </div>
                    ` : ''}
                    
                    <table>
                        <thead>
                            <tr>
                                <th>Priority</th>
                                <th>Rego</th>
                                <th>Vehicle</th>
                                <th>Pick Up</th>
                                <th>Due / Status</th>
                                <th>Work Required</th>
                                <th>VIN</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${activeJobs.map((job, index) => {
                                const isUrgent = job.isUrgent;
                                const hasCompletion = !!job.completionDate;
                                const isOverdue = hasCompletion && new Date(job.completionDate) < new Date();
                                const rowClass = isUrgent ? 'urgent' : '';
                                
                                let statusDisplay = '';
                                if (hasCompletion) {
                                    statusDisplay = formatDate(job.completionDate);
                                    if (isOverdue) statusDisplay += ' ⚠ OVERDUE';
                                } else if (job.noCompletion) {
                                    statusDisplay = 'TBD';
                                } else {
                                    statusDisplay = `${job.daysSincePickup} days old ⚠ SET DATE`;
                                }
                                
                                return `
                                <tr class="${rowClass}">
                                    <td><strong>${index + 1}</strong></td>
                                    <td><span class="reg">${job.regNumber}</span></td>
                                    <td><strong>${job.carModel}</strong>${job.daysSincePickup > 0 ? `<br><span class="days-old">${job.daysSincePickup} days in queue</span>` : ''}</td>
                                    <td>${formatDate(job.pickupDate)}</td>
                                    <td class="${isUrgent || isOverdue ? 'urgent-text' : ''}">${statusDisplay}</td>
                                    <td>${job.workRequired}</td>
                                    <td style="font-family: monospace; font-size: 11px;">${job.vinNumber || '-'}</td>
                                </tr>
                                `;
                            }).join('')}
                        </tbody>
                    </table>
                    
                    ${sortedJobs.some(j => j.isCompleted) ? `
                    <h2 style="color: #4dabf7; margin-top: 40px; border-bottom: 2px solid #4dabf7; padding-bottom: 10px;">Completed Jobs</h2>
                    <table>
                        <thead>
                            <tr style="background: #4dabf7;">
                                <th>Rego</th>
                                <th>Vehicle</th>
                                <th>Completed</th>
                                <th>Work Done</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${sortedJobs.filter(j => j.isCompleted).map(job => `
                                <tr style="opacity: 0.7;">
                                    <td><span class="reg">${job.regNumber}</span></td>
                                    <td>${job.carModel}</td>
                                    <td>${job.completionDate ? formatDate(job.completionDate) : 'N/A'}</td>
                                    <td>${job.workRequired}</td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                    ` : ''}
                    
                    ${sortedJobs.some(j => j.photos.length > 0) ? `
                    <div style="margin-top: 40px; page-break-before: always;">
                        <h2 style="color: #e63946; border-bottom: 3px solid #e63946; padding-bottom: 10px;">Photo Documentation</h2>
                        ${sortedJobs.map(job => job.photos.length > 0 ? `
                            <div style="margin-bottom: 30px; page-break-inside: avoid;">
                                <h3 style="color: #0a0e27; margin-bottom: 10px;">${job.carModel} (${job.regNumber})</h3>
                                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                                    ${job.photos.map(photo => `<img src="${photo}" style="width: 150px; height: 150px; object-fit: cover; border-radius: 8px; border: 2px solid #ddd;">`).join('')}
                                </div>
                            </div>
                        ` : '').join('')}
                    </div>
                    ` : ''}
                    
                    <div class="footer">
                        <p>Detailing Auto Care SA - Professional Automotive Detailing & Paint Correction</p>
                        <p style="margin-top: 10px; color: #e63946; font-weight: 700;">This run sheet is confidential and for internal use only.</p>
                    </div>
                    
                    <div class="no-print" style="margin-top: 30px; text-align: center;">
                        <button onclick="window.print()" style="padding: 15px 30px; background: #e63946; color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 16px;">🖨️ Print Run Sheet</button>
                    </div>
                </body>
                </html>
            `;
            
            const printWindow = window.open('', '_blank');
            printWindow.document.write(printContent);
            printWindow.document.close();
        }
        
        function switchTab(tab) {
            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            
            if (tab === 'jobs') {
                document.getElementById('jobsView').classList.add('active');
                document.querySelectorAll('.nav-tab')[0].classList.add('active');
                renderJobs();
            } else {
                document.getElementById('newJobView').classList.add('active');
                document.querySelectorAll('.nav-tab')[1].classList.add('active');
            }
        }
        
        function formatDate(dateStr) {
            if (!dateStr || dateStr === 'TBD') return 'TBD';
            try {
                const [year, month, day] = dateStr.split('-');
                return `${day}/${month}/${year}`;
            } catch {
                return dateStr;
            }
        }
        
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }
        
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('data:text/javascript,' + encodeURIComponent(`
                self.addEventListener('fetch', event => {
                    event.respondWith(fetch(event.request).catch(() => {
                        return new Response('Offline mode');
                    }));
                });
            `)).catch(() => console.log('SW registration skipped'));
        }
    </script>
</body>
</html>
